# ── Secrets (never commit) ────────────────────────────────────────────────
# Real secrets live only in .env files + your password manager. Examples are tracked.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
**/CREDENTIALS.md
*.pem
*.private-key.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.so

# ── Tooling caches / virtualenvs ──────────────────────────────────────────
.venv/
**/.venv/
.uv-cache/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# ── Runtime state & data dumps (the ledger SQLite is the only runtime state) ─
*.db
*.sqlite
*.sqlite3
*.tar.gz
*.tgz
# improvement-loop runtime evidence + active-version state (data/calibration and
# data/sealed-evals ARE committed inputs; these output dirs are not)
data/improvement/
# scan feature-log output (card_features.jsonl); regenerated each run
data/discovery/
# runtime ledger state
data/ledger.db
# job-search profile, generated resumes, job descriptions, and recruiter notes
data/job_search/
generated/improvements-board.json
*.zip
"updated files"
updated files

# ── AppFlowy / GrowthOS local state & backups (kept on disk, never pushed) ──
archive/appflowy/backups/
archive/appflowy/files.zip
archive/appflowy/extracted/
growth_os/_state/
growth_os/_export/

# ── Disposable generated output (regenerate: `make render` / `make schema`) ─
generated/litellm-config.yaml
generated/json-schema/
generated/*.md
# scan feeds (regenerate: `cc research-digest feed` / `make model-scout`)
generated/research-digest-feed.json
generated/model-scout-feed.json
# content-pipeline outputs (briefs/claims/verifications/reference clusters/style
# patterns embed personal repo + author summaries; regenerated each run)
generated/content-brief.json
generated/content-claims.json
generated/content-verifications.json
generated/reference-clusters.json
generated/reference-people.json
generated/style-patterns.json
# post-performance metrics cache; regenerated from platform APIs
data/performance/

# ── LinkedIn content pipeline runtime state — NEVER commit ──────────────────
# token store holds the OAuth access token (a secret); ledger/lock are runtime
generated/linkedin-token.json
generated/linkedin-published.json
generated/linkedin-publish.lock

# ── Cockpit shared chat threads — conversation content, per-deployment ───────
generated/chat-threads.json

# ── Gateway turn transcripts — full-fidelity conversation content, never commit ──
generated/chat-transcripts/

# ── Content UX runtime artifacts (regenerate: `cc reference index --rebuild`) ─
# the reference index (with embeddings), HTML previews, and the local posts store
data/reference/
generated/preview/
generated/content-posts.json
# content-engine generated outputs (briefs/claims/analysis) — disposable, never commit
generated/content-brief.json
generated/content-claims.json
generated/content-verifications.json
generated/reference-clusters.json
generated/reference-people.json
generated/style-patterns.json

# ── Cross-conversation memory store — per-deployment runtime state ───────────
# project/board/user-preference memory; sharing is a deliberate export, not a commit
generated/memory/

# ── Kanban event log — source-of-truth event stream, per-deployment runtime ──
generated/kanban-events.jsonl

# ── Frontier-router usage ledger + benchmark reports — real per-deployment spend
# data and point-in-time comparison results, regenerate via make frontier-router-* ──
generated/frontier-router-usage.jsonl
generated/frontier-benchmark-report.json
generated/frontier-benchmark-report.md

# ── Local-frontier (colibrì) usage ledger + benchmark reports — same reasoning,
# regenerate via make colibri-benchmark ──
generated/local-frontier-usage.jsonl
generated/local-frontier-benchmark-report.json
generated/local-frontier-benchmark-report.md

# ── Local staging / scratch ───────────────────────────────────────────────
_staging/
.codex_tmp/

# ── Runtime logs (the gateway writes a size-bounded, rotating gateway.log; the ─
#    supervisor writes gateway-supervisor.log; both regenerate on run) ─────────
*.log
*.log.*

# ── Capability-evaluation vendored binaries (pinned + re-downloadable; the ──
#    version + sha256 live in each candidate's install-manifest.json, so the
#    binary is reproducible and must not be committed as a source artifact). ─
evaluation/capability-assessment/abtop/bin/

# ── OS / editor noise ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# improvement-loop pytest runtime artifacts (cache/proposals are disposable)
generated/pytest-cache/
generated/pytest-proposals/
generated/pytest-tmp*/

# ── Internal board card store — REAL job pipeline data (companies, salaries,
#    achievement ids). Per-deployment runtime state like kanban-events.jsonl;
#    never committed. ─────────────────────────────────────────────────────────
generated/boards/

# ── Cockpit validation screenshots — show the real application pipeline; keep
#    local as proof, never push. Browser-automation profile dirs likewise. ────
generated/cockpit-*.png

# Local aggregate-only Life Center capacity measurements. These may reveal
# private storage usage patterns and are intentionally never committed.
generated/life-center-growth/
.tmp-*/
