{
  "name": "cc-repo-task python-ml",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "pip install -r requirements.txt pre-commit && pre-commit install",
  "remoteEnv": {
    "JUDGE_HOST": "http://judge-gate:8088"
  },
  "containerEnv": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  },
  "runArgs": ["--network=host"]
}
