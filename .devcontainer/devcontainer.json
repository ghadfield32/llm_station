{
  "name": "llm-station repo task",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm@sha256:7876580dc67fd460fd962f004cbeb480027e9bbc0657096f1087db11f9eaff39",
  "remoteUser": "vscode",
  "containerEnv": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "UV_LINK_MODE": "copy"
  },
  "postCreateCommand": "python -m pip install --user uv==0.8.11 && python -m uv sync --frozen --extra dev --extra gateways",
  "postStartCommand": "python -m uv run --frozen cc validate",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
