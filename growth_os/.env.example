# First-party Command Center board storage (no external board credentials).
GROWTHOS_BOARD_STORE=../generated/boards
GROWTHOS_KANBAN_EVENT_LOG=../generated/kanban-events.jsonl

# Optional API key for higher GitHub source limits. Keep real values in .env.
GITHUB_TOKEN=

GROWTHOS_DRY_RUN=false
GROWTHOS_STATE_DIR=./_state
GROWTHOS_LOG_LEVEL=INFO