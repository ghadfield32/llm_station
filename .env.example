# Copy to ".env". NEVER commit (it's gitignored). Keep a copy in a password manager.
# `make setup` or `.\scripts\cc.ps1 init-env` generates the three local secrets.
LITELLM_MASTER_KEY=
POSTGRES_PASSWORD=
LEDGER_APPROVAL_SECRET=
# Local-model tier. On Windows/local Docker, host.docker.internal usually reaches
# Ollama on the host. On the VPS, replace with the 4090 Tailscale URL.
OLLAMA_API_BASE=http://host.docker.internal:11434
# created by `make keys` after first boot:
HERMES_LITELLM_KEY=
JUDGE_GATE_LITELLM_KEY=
# fine-grained PAT for MVP; migrate to a GitHub App long-term (see docs/github/github-safety.md)
GITHUB_TOKEN=
# operator/reporting defaults
LITELLM_URL=http://localhost:4000
LEDGER_HOST_PORT=8091
LEDGER_BASE_URL=http://localhost:8091

# ── Agent Sessions (Claude Agent / Codex Agent host worker) ──
# The worker runs on the HOST (`.\scripts\start_agent_worker.ps1 start`), never
# in the cockpit container — it owns real SDK/CLI authentication. Generate a
# token with: uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
# Local setup enables the real read-only sessions and honest Usage & Limits
# collectors. init-env generates AGENT_WORKER_TOKEN; Fake Agent remains off.
AGENT_WORKER_TOKEN=
AGENT_WORKER_USAGE=1
KANBAN_UI_AGENT_SESSIONS_ENABLED=1
KANBAN_UI_FAKE_AGENT_ENABLED=0
KANBAN_UI_USAGE_ENABLED=1
KANBAN_UI_USAGE_CODEX=1
KANBAN_UI_USAGE_CLAUDE=1
KANBAN_UI_USAGE_LEDGER=1


# ── Chat channels (configs/channels.yaml turns them on; tokens live here only) ──
# Per-transport setup steps: docs/architecture/channels.md
# Discord — https://discord.com/developers/applications (enable MESSAGE CONTENT intent)
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_CHANNEL_ID=

# Slack — https://api.slack.com/apps (Socket Mode: xoxb- bot token + xapp- app token)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_CHANNEL_IDS=

# Telegram — @BotFather token; optional comma-separated chat-id allowlist
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# WhatsApp — Meta Cloud API (needs a public HTTPS webhook; see docs/architecture/channels.md)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ALLOWED_NUMBERS=
WHATSAPP_WEBHOOK_HOST=0.0.0.0
WHATSAPP_WEBHOOK_PORT=8080


# ── LinkedIn content pipeline (configs/content.yaml; command_center.cli.linkedin_publish) ──
# Create a LinkedIn Developer app (https://www.linkedin.com/developers/apps):
#   products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn";
#   for the World Model Sports Page also request "Community Management API"
#   (w_organization_social) and verify the Page. Redirect URL must match below.
# Then: `cc linkedin-publish --login` once to authorize + persist the token.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback
# World Model Sports company Page URN, e.g. urn:li:organization:12345678
# (Page admin -> Admin tools / the numeric id in the Page URL). Member posts
# need no URN - it's resolved from the token owner.
LINKEDIN_WMS_ORG_URN=

# Second-GPU failover endpoint for the channels gateway (5080 laptop on the
# tailnet). Uncomment + set, bring up Ollama there (OLLAMA_HOST=0.0.0.0,
# pull a <=16GB model), then uncomment the triage-5080 candidate in
# configs/models.yaml and `make models`. Left unset = single-GPU (fail-closed).
# OLLAMA_API_BASE_5080=http://msi:11434




# github app details
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_APP_NAME=llm-station-command-center
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
# Optional one-run owner/admin observer token for read-only branch-protection verification.
# Do not use this for app writes, repo tasks, pushes, settings changes, merges, or deploys.
GITHUB_OWNER_ADMIN_TOKEN=



# Frontier-router backup lane (configs/frontier-router-{providers,budgets}.yaml) —
# a SEPARATE, budgeted, opt-in escalation to paid open-weight models too large for
# local VRAM (GLM-5.2 / DeepSeek V4 Pro / Kimi K2.6). Left commented = the lane
# stays off and `cc validate`'s forbidden-provider scan stays clean (its default
# behavior). To enable: uncomment below, set configs/frontier-router-budgets.yaml
# default.enabled: true, then validate with
# `make frontier-router-egress-check` (NOT plain `cc validate`, which stays
# strict by design and will keep failing on this key — that is intentional).
# OPENROUTER_API_KEY=
# ZAI_API_KEY=
# Immutable Kanban/TODO snapshots. Keep the default for local logical recovery;
# point this at encrypted external/off-host storage for host/disk-loss recovery.
KANBAN_BACKUP_HOST_PATH=./backups



AGENT_WORKER_TOKEN=""

