# life-center-infra — environment references
# Copy to `.env` (gitignored). NEVER commit. Keep a copy in a password manager.
# `lc setup` copies this file and generates the local secrets marked (generated).
# No plaintext secret belongs in this example file.

# ── core paths ───────────────────────────────────────────────────────────────
# Appdata (SSD): service databases/config. Data pool (mirror): originals/media.
LC_APPDATA=./appdata
LC_DATA=/tank
LC_BACKUP_TARGET=./backups
LC_TZ=America/New_York
# Compose project + shared network name (do not change casually).
COMPOSE_PROJECT_NAME=life-center

# ── loopback ports (bind 127.0.0.1 only; shared via Tailscale Serve) ──────────
# Chosen to avoid the llm_station main stack's ports (litellm 4000, ledger 8091,
# judge-gate 8088, uptime-kuma 3001, agent-kanban-ui 8787, airflow 8080/8090) and
# any other desktop-resident stack (traefik 8081/8095, CVAT/Betts 8080/8050/etc.).
# Re-check `docker ps` before changing these if you run other stacks too.
#
# LC_TAILNET_HOST: your tailnet's MagicDNS name (e.g. `tailscale status` / `tailscale
# serve status`), e.g. yourmachine.tailXXXXX.ts.net. When set, `lc links`/the Launch
# tab rewrite every http://127.0.0.1:<port> app link to https://<LC_TAILNET_HOST>:<port>
# — this only works if you've also run `tailscale serve --bg --https=<port>
# http://127.0.0.1:<port>` for that same port (same port both sides). Leave unset to
# keep loopback-only links (desktop-only access, no phone/remote reachability).
# LC_TAILNET_HOST=yourmachine.tailXXXXX.ts.net
DOCKGE_PORT=5001
UPTIME_KUMA_PORT=3011
NEXTCLOUD_PORT=8085
IMMICH_PORT=2283
JELLYFIN_PORT=8096
AUDIOBOOKSHELF_PORT=13378
CALIBRE_WEB_PORT=8083
PAPERLESS_PORT=8000
LINKWARDEN_PORT=3010
FRESHRSS_PORT=8082
MEALIE_PORT=9925
HOMEBOX_PORT=7745
STIRLING_PDF_PORT=8084
ACTUAL_PORT=5006
ADGUARD_PORT=3000
VAULTWARDEN_PORT=8222

# ── secrets (generated by `lc setup`; placeholders only here) ─────────────────
# NEXTCLOUD_ADMIN_PASSWORD=            # (generated)
# NEXTCLOUD_DB_PASSWORD=               # (generated)
# IMMICH_DB_PASSWORD=                  # (generated)
# PAPERLESS_SECRET_KEY=                # (generated)
# PAPERLESS_DB_PASSWORD=               # (generated)
# LINKWARDEN_NEXTAUTH_SECRET=          # (generated)
# LINKWARDEN_DB_PASSWORD=              # (generated)
# ACTUAL_PASSWORD=                     # (generated)
# VAULTWARDEN_ADMIN_TOKEN=             # (generated; vault tier is admitted LAST)

# ── backups: restic (3-2-1) ──────────────────────────────────────────────────
# Local encrypted repo + Backblaze B2 off-site (client-side encrypted).
# RESTIC_PASSWORD=                     # (generated; also stored offline)
RESTIC_REPOSITORY=/backups/restic
# B2 off-site (uncomment + scope an append/write-only credential when admitted):
# RESTIC_B2_REPOSITORY=b2:your-bucket:life-center
# B2_ACCOUNT_ID=
# B2_ACCOUNT_KEY=

# ── dev lane: Open Design ─────────────────────────────────────────────────────
# Open Design runs on the desktop/laptop, NOT on the appliance. These control the
# dev-lane bring-up + the .od/ backup hook (see dev-lane/open-design/).
OPEN_DESIGN_DIR=./dev-lane/open-design/open-design
OPEN_DESIGN_OD_DIR=./dev-lane/open-design/open-design/.od
OPEN_DESIGN_BACKUP_TARGET=/tank/models-archive/open-design
# Coding agent used to power the canvas (auto-detected on PATH if unset):
# OPEN_DESIGN_AGENT=claude-code
