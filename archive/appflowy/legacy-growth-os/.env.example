# ---- AppFlowy Cloud (your self-hosted instance) ----
APPFLOWY_BASE_URL=https://appflowy.your-domain.tld
APPFLOWY_EMAIL=you@example.com
APPFLOWY_PASSWORD=change-me
APPFLOWY_WORKSPACE_ID=                 # filled after first `list-workspaces`

# ---- Optional API keys (raise rate limits / quality) ----
GITHUB_TOKEN=                          # a classic PAT, read-only is fine
# OPENAI_API_KEY / ANTHROPIC_API_KEY only needed if you enable embedding-based scoring

# ---- Behaviour ----
GROWTHOS_DRY_RUN=true                  # true = write CSVs only; flip to false once the write path is verified
GROWTHOS_STATE_DIR=./_state
GROWTHOS_LOG_LEVEL=INFO
